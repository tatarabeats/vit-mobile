<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0E1A">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFF0C040"
            android:paddingBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Groq APIキー（音声認識）"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:paddingTop="8dp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/apiKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="gsk_..."
            android:inputType="textPassword"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#80FFFFFF"
            android:background="#FF1A2440"
            android:padding="14dp"
            android:autofillHints="password" />

        <Button
            android:id="@+id/saveApiKey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="保存"
            android:textColor="#FF0A0E1A"
            android:backgroundTint="#FFF0C040" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Anthropic APIキー（句読点・誤字補正、任意）"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:paddingTop="20dp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/anthropicKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-ant-..."
            android:inputType="textPassword"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#80FFFFFF"
            android:background="#FF1A2440"
            android:padding="14dp"
            android:autofillHints="password" />

        <Button
            android:id="@+id/saveAnthropicKey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="保存"
            android:textColor="#FF0A0E1A"
            android:backgroundTint="#FFF0C040" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/llmFixSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="LLM補正を有効化（Anthropic APIキー必須）"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="辞書（住所・固有名詞、改行区切り）"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:paddingTop="20dp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/dictionaryInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="120dp"
            android:gravity="top|start"
            android:hint="例:&#10;和歌山県有田市初島町&#10;和歌山県東牟婁郡那智勝浦町&#10;白浜町、上富田町、新宮市..."
            android:inputType="textMultiLine"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#80FFFFFF"
            android:background="#FF1A2440"
            android:padding="14dp"
            android:textSize="14sp" />

        <Button
            android:id="@+id/saveDictionary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="辞書を保存"
            android:textColor="#FF0A0E1A"
            android:backgroundTint="#FFF0C040" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ショートカット（話した言葉 → 入力される文字列）"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:paddingTop="20dp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/snippetsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:gravity="top|start"
            android:hint="例:&#10;住所|岡山県岡山市北区〇〇1-2-3&#10;電話|090-1234-5678&#10;メール|shunp@example.com"
            android:inputType="textMultiLine"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#80FFFFFF"
            android:background="#FF1A2440"
            android:padding="14dp"
            android:textSize="14sp" />

        <Button
            android:id="@+id/saveSnippets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="ショートカットを保存"
            android:textColor="#FF0A0E1A"
            android:backgroundTint="#FFF0C040" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:background="#FFF0C040" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. 権限設定（初回のみ）"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:paddingBottom="6dp" />

        <Button
            android:id="@+id/btnOverlayPerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="他のアプリの上に表示"
            android:textColor="#FF0A0E1A"
            android:backgroundTint="#FFF0C040" />

        <Button
            android:id="@+id/btnAccessibilityPerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="ユーザー補助を有効化"
            android:textColor="#FF0A0E1A"
            android:backgroundTint="#FFF0C040" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:background="#FFF0C040" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4. 起動 / 停止"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:paddingBottom="6dp" />

        <Button
            android:id="@+id/btnStartOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="フロートマイクを起動"
            android:textColor="#FF0A0E1A"
            android:backgroundTint="#FFF0C040" />

        <Button
            android:id="@+id/btnStopOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="停止"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FF1A2440" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:lineSpacingExtra="4dp"
            android:text="使い方:\n・タップで録音開始/停止\n・録音中に長押しでキャンセル\n・ドラッグで位置移動" />
    </LinearLayout>
</ScrollView>
