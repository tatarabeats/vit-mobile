<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:paddingBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Groq APIキー（音声認識）"
            android:textStyle="bold"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/apiKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="gsk_..."
            android:inputType="textPassword"
            android:autofillHints="password" />

        <Button
            android:id="@+id/saveApiKey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="保存" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Anthropic APIキー（句読点・誤字補正、任意）"
            android:textStyle="bold"
            android:paddingTop="20dp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/anthropicKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-ant-..."
            android:inputType="textPassword"
            android:autofillHints="password" />

        <Button
            android:id="@+id/saveAnthropicKey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="保存" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/llmFixSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="LLM補正を有効化（Anthropic APIキー必須）" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:background="#666" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. 権限設定（初回のみ）"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btnOverlayPerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="他のアプリの上に表示（オーバーレイ）" />

        <Button
            android:id="@+id/btnAccessibilityPerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ユーザー補助を有効化" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:background="#666" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4. 起動 / 停止"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btnStartOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="フロートマイクを起動" />

        <Button
            android:id="@+id/btnStopOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="停止" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textSize="12sp"
            android:text="使い方:\n・タップで録音開始/停止\n・録音中は録音時間が上に表示\n・録音中に長押しでキャンセル\n・ドラッグで位置移動" />
    </LinearLayout>
</ScrollView>
